# ── Large resource files — needed for build, tracked in git ─────────────────
# (all individual files are under GitHub's 100 MB per-file hard limit)

# Zip artifacts and source packages — do NOT commit
/Assets/CelestiaVR_resources/PlanetTextures.zip
/Assets/CelestiaVR_resources/Space Graphics Toolkit v4.1/*.unitypackage

# Duplicate star catalog (Assets/Data/hyg_v42.csv is the tracked copy)
/Assets/CelestiaVR_resources/HYG_StarDataBase/hyg_v42.csv

# Space Graphics Toolkit plugin — not used by this project
/Assets/Plugins/

# Stellarium full skycultures repo (277 MB raw clone — only parsed output is needed)
/Assets/CelestiaVR_resources/ConstellationArt/

# Keep meta so Unity doesn't lose folder references for ignored dirs
!/Assets/CelestiaVR_resources/ConstellationArt.meta
!/Assets/Plugins.meta

