# Unity generated
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Unity asset meta files for ignored assets
/[Ll]ibrary/ShaderCache/

# Autogenerated VS/MD solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed assets (large, regenerated)
/Assets/AssetStoreTools*

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp

# VS Code
.vscode/

# Rider
.idea/

# Large resource files — keep out of git (too big, stored locally)
/Assets/CelestiaVR_resources/Space\ Graphics\ Toolkit\ v4.1/
/Assets/CelestiaVR_resources/HYG_StarDataBase/hyg_v42.csv
/Assets/CelestiaVR_resources/PlanetTextures/*.glb
/Assets/Plugins/

# Keep meta files for the above (so Unity doesn't lose references)
!/Assets/CelestiaVR_resources/Space\ Graphics\ Toolkit\ v4.1/*.meta
!/Assets/CelestiaVR_resources/HYG_StarDataBase/*.meta
!/Assets/CelestiaVR_resources/PlanetTextures/*.meta
