# ── Large resource files — stored locally, not in git ────────────────────────

# Star catalog (119k rows, ~25 MB)
/Assets/CelestiaVR_resources/HYG_StarDataBase/hyg_v42.csv
/Assets/Data/hyg_v42.csv

# Planet & environment 3D models
/Assets/CelestiaVR_resources/PlanetTextures/*.glb
/Assets/CelestiaVR_resources/Environment/*.glb
/Assets/CelestiaVR_resources/PlanetTextures.zip

# Space Graphics Toolkit (large unitypackage + installed plugin)
/Assets/CelestiaVR_resources/Space Graphics Toolkit v4.1/
/Assets/Plugins/

# Milky Way / deep sky images (large JPG/TIF)
/Assets/CelestiaVR_resources/MilkyWay/*.jpg
/Assets/CelestiaVR_resources/MilkyWay/*.tif
/Assets/CelestiaVR_resources/MilkyWay/*.png
/Assets/CelestiaVR_resources/DeepSkyImages/*.jpg
/Assets/CelestiaVR_resources/DeepSkyImages/*.png

# Stellarium full skycultures repo (277 MB, only index.json + modern PNGs are needed)
/Assets/CelestiaVR_resources/ConstellationArt/

# Keep meta files so Unity doesn't lose folder references
!/Assets/CelestiaVR_resources/HYG_StarDataBase/*.meta
!/Assets/CelestiaVR_resources/PlanetTextures/*.meta
!/Assets/CelestiaVR_resources/Environment/*.meta
!/Assets/CelestiaVR_resources/MilkyWay/*.meta
!/Assets/CelestiaVR_resources/DeepSkyImages/*.meta
!/Assets/CelestiaVR_resources/ConstellationArt.meta
!/Assets/Plugins.meta

# Baked lighting (regenerated by Unity, large EXR files)
/Assets/Scenes/**/*.exr
/Assets/Scenes/**/*.exr.meta

# Android build output
/BuildOutput/
/AndroidBuild/
/ExportedProject/
/GradleProject/
gradle-wrapper.jar
local.properties

# Unity build artifacts at project root
*_DoNotShip/
*_BackUpThisFolder_ButDontShipItWithYourGame/
.utmp/

# Quest / Android device specific
*.symbols.zip
